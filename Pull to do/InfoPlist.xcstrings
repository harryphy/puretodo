    "NSCameraUsageDescription" : {
      "comment" : "Privacy - Camera Usage Description",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اسمح بالوصول إلى الكاميرا لإضافة صور إلى مهامك."
