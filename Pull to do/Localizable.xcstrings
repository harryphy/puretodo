    "← Swipe an item left to delete" : {
      "comment" : "Delete",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "← اسحب لليسار للحذف"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "← Nach links wischen, um zu löschen"
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "← Σύρετε προς τα αριστερά για διαγραφή"
          }
